# ============ LLM 配置 ============
LLM_MODEL_ID=gpt-4
LLM_API_KEY=your-openai-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_TEMPERATURE=0.7

# ============ 高德地图 API (Outfit/Trip) ============
AMAP_API_KEY=your_amap_api_key

# ============ Tavily 搜索 (Search 子图) ============
TAVILY_API_KEY=your_tavily_api_key

# ============ GitHub (Academic 子图) ============
GITHUB_TOKEN=your_github_token

# ============ 服务配置 ============
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ============ 开发模式 ============
# 设为 true 时，所有工具使用 Mock 数据
MOCK_MODE=false

# ============ CORS 配置 ============
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# ============ 记忆系统配置 ============

# 记忆系统开关
MEMORY_ENABLED=true
MEMORY_FALLBACK_ON_ERROR=true

# Embedding 配置
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Redis 配置（短期记忆）
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SESSION=3600
REDIS_TTL_CONTEXT=1800
REDIS_TTL_FEEDBACK=86400

# Milvus 配置（长期记忆）
MILVUS_ENABLED=false
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=universal_agent_memories
MILVUS_INDEX_TYPE=HNSW
MILVUS_METRIC_TYPE=COSINE

# 记忆检索配置
MEMORY_RETRIEVE_THRESHOLD=0.3
MEMORY_MAX_RESULTS=10
MEMORY_MIN_SCORE=0.6
MEMORY_COMPRESSION_ENABLED=true
MEMORY_MAX_ITEMS_IN_BUNDLE=5

# 记忆存储配置
MEMORY_STORE_IMPORTANCE_THRESHOLD=0.7
MEMORY_STORE_CONFIDENCE_THRESHOLD=0.6
MEMORY_AUTO_UPGRADE_TO_LONG_TERM=false
